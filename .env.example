# Anthropic API Key for Claude integration
ANTHROPIC_API_KEY=your-api-key-here

# Path to projects folder (absolute path on host)
PROJECTS_ROOT=/path/to/your/projects

# Path to skills folder (absolute path on host, optional - defaults to ./skills)
SKILLS_PATH=/path/to/skills

# Path to data folder for SQLite database (optional - defaults to ./data)
DATA_PATH=/path/to/data
