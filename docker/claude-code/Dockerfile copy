# ============================================
# Claude Code Container for Ralph
# ============================================
# This container runs Claude Code CLI for brainstorming and story execution.
# It's spawned by Ralph using Docker-out-of-Docker (DooD) pattern.
#
# Build:   docker build -t claude-sandbox:latest ./docker/claude-code
# Test:    docker run --rm -it -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY claude-sandbox:latest --version
#
FROM node:20-slim

ARG CLAUDE_CODE_VERSION=latest

# Install essential tools for development tasks
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Git for version control
    git \
    # Network utilities
    curl \
    ca-certificates \
    # Process management
    procps \
    # JSON processing (useful for Claude)
    jq \
    # File utilities
    less \
    # Python (many projects need it)
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Configure git for container use
RUN git config --global --add safe.directory /workspace && \
    git config --global init.defaultBranch main

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# Create directories
RUN mkdir -p /workspace /skills /root/.claude

# Working directory for projects
WORKDIR /workspace

# Environment setup
ENV NODE_ENV=production
# Disable interactive prompts
ENV CI=true
# Enable non-interactive mode hints for Claude
ENV CLAUDE_CODE_ENTRYPOINT=docker

# Healthcheck - verify claude is available
HEALTHCHECK --interval=60s --timeout=10s --start-period=5s --retries=2 \
    CMD claude --version || exit 1

# Default entrypoint
ENTRYPOINT ["claude"]

# Default command shows help
CMD ["--help"]
